{
	"name": "EditAccount",
	"version": "3.0.0-alpha",
	"author": [
		"Łukasz Garczewski",
		"Jack Phoenix",
		"WikiTeq"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:EditAccount",
	"descriptionmsg": "editaccount-desc",
	"type": "specialpage",
	"requires": {
		"MediaWiki": ">= 1.36.0"
	},
	"license-name": "GPL-2.0-or-later",
	"GroupPermissions": {
		"*": {
			"editaccount": false
		},
		"staff": {
			"editaccount": true
		}
	},
	"AvailableRights": [
		"editaccount"
	],
	"SpecialPages": {
		"EditAccount": {
			"class": "MediaWiki\\Extension\\EditAccount\\SpecialEditAccount",
			"services": [
				"PasswordFactory",
				"UserNameUtils",
				"UserOptionsManager",
				"UserFactory",
				"UserIdentityLookup",
				"LinkRenderer",
				"DBLoadBalancer"
			]
		},
		"CloseAccount": {
			"class": "MediaWiki\\Extension\\EditAccount\\SpecialCloseAccount",
			"services": [
				"UserGroupManager",
				"UserNameUtils",
				"UserOptionsManager",
				"PasswordFactory",
				"UserFactory",
				"DBLoadBalancer"
			]
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\EditAccount\\": "includes/"
	},
	"LogTypes": [
		"editaccnt"
	],
	"LogRestrictions": {
		"editaccnt": "editaccount"
	},
	"LogActionsHandlers": {
		"editaccnt/*": "LogFormatter"
	},
	"MessagesDirs": {
		"EditAccount": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"EditAccountAliases": "EditAccount.alias.php"
	},
	"Hooks": {
		"AdminLinks": "MediaWiki\\Extension\\EditAccount\\Hooks::addToAdminLinks",
		"SpecialContributionsBeforeMainOutput": "MediaWiki\\Extension\\EditAccount\\Hooks::onSpecialContributionsBeforeMainOutput"
	},
	"ResourceModules": {
		"ext.editAccount": {
			"localBasePath": "modules",
			"remoteExtPath": "EditAccount/modules",
			"styles": [
				"editAccount.css"
			]
		},
		"ext.editAccount.displayuser": {
			"localBasePath": "modules/js",
			"remoteExtPath": "EditAccount/modules/js",
			"packageFiles": [
				"displayuser.js"
			],
			"dependencies": [
				"jquery"
			]
		}
	},
	"manifest_version": 2
}
